# انسخي إلى .env.production قبل: npm run build
# استبدلي YOUR-DOMAIN بالدومين الحقيقي

# إذا الـ Backend على نفس الدومين (VPS + Apache proxy /api):
# VITE_API_URL=/api
# VITE_WS_URL=

# إذا الـ Backend على سيرفر منفصل (Railway, Render, VPS آخر):
VITE_API_URL=https://api.YOUR-DOMAIN.com/api
VITE_WS_URL=https://api.YOUR-DOMAIN.com
